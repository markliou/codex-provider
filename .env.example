CODEX_POOL_API_KEY=replace-with-a-long-random-api-key
CODEX_POOL_ADMIN_PASSWORD_HASH=pbkdf2-sha256:replace-with-output-from-hash-password
CODEX_POOL_DATA_DIR=/data
CODEX_POOL_PUBLIC_ADDR=:8317
CODEX_POOL_ADMIN_ADDR=127.0.0.1:8318
CODEX_POOL_DEFAULT_MODEL=gpt-5.5(xhigh)
# Balance new sessions across equal-priority healthy accounts. Use sticky_failover
# for the legacy strict-priority behavior.
CODEX_POOL_ROUTING_STRATEGY=sticky_balanced
CODEX_POOL_SESSION_AFFINITY_TTL_MS=86400000
CODEX_POOL_MAX_RETRY_ACCOUNTS=0
CODEX_POOL_PROMPT_CACHE_KEY_MODE=auto
# Preserve the client key by default. lineage/project/user explicitly replace it
# with a deterministic hashed and bucketed upstream key.
CODEX_POOL_PROMPT_CACHE_KEY_POLICY=preserve
CODEX_POOL_PROMPT_CACHE_KEY_SCOPE=auto
CODEX_POOL_PROMPT_CACHE_BUCKETS=4
# Optional override. Default is 24h; use passthrough to preserve the upstream default.
# CODEX_POOL_PROMPT_CACHE_RETENTION=24h
# Optional. When true, non-Pro accounts are preferred and active Pro sticky sessions
# move back to non-Pro accounts once any eligible non-Pro account becomes available.
# CODEX_POOL_PRESERVE_PRO_QUOTA=false

# Codex device-auth requests use the bundled loopback-only CLIProxyAPI sidecar.
# CODEX_POOL_CODEX_GATEWAY_MODE=sidecar

# Optional test/compatibility override. Default is CODEX_POOL_CODEX_BASE_URL + /wham/usage.
# CODEX_POOL_CODEX_USAGE_URL=https://chatgpt.com/backend-api/wham/usage

# Optional legacy provider gateway for non-Codex OpenAI-compatible providers.
# Codex/ChatGPT accounts should be added in the admin UI and authenticated with device auth.
# CODEX_POOL_UPSTREAM_BASE_URL=https://api.openai.com/v1
# CODEX_POOL_UPSTREAM_API_KEY=sk-...
# CODEX_POOL_UPSTREAM_WIRE_API=responses
