CODEX_POOL_API_KEY=replace-with-a-long-random-api-key
CODEX_POOL_ADMIN_PASSWORD_HASH=pbkdf2-sha256:replace-with-output-from-hash-password
CODEX_POOL_DATA_DIR=/data
CODEX_POOL_PUBLIC_ADDR=:8317
CODEX_POOL_ADMIN_ADDR=127.0.0.1:8318
CODEX_POOL_DEFAULT_MODEL=gpt-5.4

